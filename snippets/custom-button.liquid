{% comment %}
  This is a reusable button snippet that can render either a form button (<button>) 
  or a standard link anchor (<a>), depending on how you call it.
{% endcomment %}

{% if tag == 'button' or type != blank %}
  {% comment %} If tag is set to 'button' or a button type is provided, we output a button element {% endcomment %}
  <button
    {% if type != blank %}
      type="{{ type }}"
    {% endif %}
    class="btn-slide-hover {{ class }}"
    {% if id != blank %}
      id="{{ id }}"
    {% endif %}
    {% if disabled %}
      disabled
    {% endif %}
  >
    <span class="{{ text_class | default: 'custom-btn-text' }}">{{ text }}</span>
    
    {% comment %} Render the icon (either an uploaded Shopify image or raw SVG/HTML) {% endcomment %}
    {% if icon != blank %}
      <img
        src="{{ icon | image_url: width: 40 }}"
        class="{{ icon_class | default: 'custom-btn-icon' }}"
        width="20"
        height="20"
        alt=""
        loading="lazy"
      >
    {% elsif icon_svg != blank %}
      {{ icon_svg }}
    {% endif %}
  </button>
{% else %}
  {% comment %} Otherwise, default to outputting a standard navigation link {% endcomment %}
  <a
    href="{{ link | default: '#' }}"
    class="btn-slide-hover {{ class }}"
    {% if id != blank %}
      id="{{ id }}"
    {% endif %}
  >
    <span class="{{ text_class | default: 'custom-btn-text' }}">{{ text }}</span>
    
    {% comment %} Render the icon (either an uploaded Shopify image or raw SVG/HTML) {% endcomment %}
    {% if icon != blank %}
      <img
        src="{{ icon | image_url: width: 40 }}"
        class="{{ icon_class | default: 'custom-btn-icon' }}"
        width="20"
        height="20"
        alt=""
        loading="lazy"
      >
    {% elsif icon_svg != blank %}
      {{ icon_svg }}
    {% endif %}
  </a>
{% endif %}
