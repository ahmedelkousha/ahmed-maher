<section id="custom-products-grid-{{ section.id }}" class="custom-products-grid">
  {% if section.settings.title != blank %}
    <h2 class="custom-products-grid__title">{{ section.settings.title }}</h2>
  {% endif %}

  {% liquid
    # We calculate the display limits for both desktop and mobile layouts by multiplying configured rows by columns.
    # To prevent visual layout breaks when rendering, we dynamically take the larger of the two limits as our loop ceiling
    # and then clamp the loop ceiling against the hard maximum limit specified in the user customization dashboard.
    assign limit_desktop = section.settings.columns_desktop | times: section.settings.rows_desktop
    assign limit_mobile = section.settings.columns_mobile | default: 2 | times: section.settings.rows_mobile | default: 3
    assign max_limit = section.settings.max_products
    assign loop_limit = limit_desktop
    if limit_mobile > loop_limit
      assign loop_limit = limit_mobile
    endif
    if max_limit < loop_limit
      assign loop_limit = max_limit
    endif
  %}

  <div class="custom-products-grid__container">
    <div class="custom-products-grid__items">
      {% for product in section.settings.product_list limit: loop_limit %}
        {% liquid
          # Gather details about the current product: variant info and coordinate metafields for custom plus button placements on product image
          assign variant = product.selected_or_first_available_variant
          assign has_multiple_variants = false
          if product.variants.size > 1
            assign has_multiple_variants = true
          endif
          assign pos_x = product.metafields.custom.plus_position_x
          assign pos_y = product.metafields.custom.plus_position_y
        %}

        <div class="custom-product-card" id="product-card-{{ product.id }}">
          <div class="custom-product-card__media">
            {% if product.featured_image != blank %}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.title | escape }}"
                class="custom-product-card__img"
                loading="lazy"
                width="{{ product.featured_image.width }}"
                height="{{ product.featured_image.height }}"
              >
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'custom-product-card__img placeholder-svg' }}
            {% endif %}

            {% comment %} An interactive hover overlay button that serves as a direct shortcut to configure and add this product {% endcomment %}
            <button
              class="custom-product-card__quick-add-trigger"
              aria-label="Add to cart"
              data-product-id="{{ product.id }}"
              data-section-id="{{ section.id }}"
              {% if pos_x != blank and pos_y != blank %}
                style="--plus-pos-left: {{ pos_x }}%; --plus-pos-top: {{ pos_y }}%; --plus-pos-bottom: auto; --plus-pos-right: auto; --plus-pos-transform: translate(-50%, -50%);"
              {% endif %}
            >
              <img
                src="{{ 'icon-plus-custom.png' | asset_url }}"
                alt="Add to cart"
                class="custom-product-card__plus-icon"
                loading="lazy"
                width="22"
                height="22"
              >
            </button>
          </div>
          {% comment %} The quick-add popup modals (custom-quick-views-container) are rendered at the bottom of the section to keep the layout nesting clean {% endcomment %}
        </div>
      {% else %}
        {% comment %} Placeholder cards for empty product cards {% endcomment %}
        {% for i in (1..loop_limit) %}
          {% assign placeholder_num = i | modulo: 4 | plus: 1 %}
          <div class="custom-product-card custom-product-card--placeholder">
            <div class="custom-product-card__media">
              {{
                'product-'
                | append: placeholder_num
                | placeholder_svg_tag: 'custom-product-card__img placeholder-svg'
              }}
            </div>
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% comment %} We list all modals at the section root so that their high-depth overlays aren't clipped by the grid container's overflow settings {% endcomment %}
<div class="custom-quick-views-container">
  {% for product in section.settings.product_list limit: loop_limit %}
    {% liquid
      # Extract structural variants and check if this specific item has option configurations (like sizes or colors)
      assign variant = product.selected_or_first_available_variant
      assign has_multiple_variants = false
      if product.variants.size > 1
        assign has_multiple_variants = true
      endif
    %}
    {% comment %} Custom Quick View Modal: contains the quick add to card working functionality for the product {% endcomment %}
    <custom-quick-view
      id="quick-view-{{ section.id }}-{{ product.id }}"
      class="custom-quick-view"
      data-variants="{{ product.variants | json | escape }}"
    >
      <div
        class="custom-quick-view-modal"
        role="dialog"
        aria-modal="true"
        aria-labelledby="modal-title-{{ product.id }}"
      >
        <div class="custom-quick-view-modal__backdrop"></div>
        <div class="custom-quick-view-modal__content">
          <button class="custom-quick-view-modal__close" aria-label="Close quick view">&times;</button>

          {% comment %} FIRST ROW: Flex row container with image and detailed info container {% endcomment %}
          <div class="custom-quick-view__first-row">
            <!-- Left: Product Image -->
            <div class="custom-quick-view__image-container">
              {% if product.featured_image != blank %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.title | escape }}"
                  class="custom-quick-view__img"
                  loading="lazy"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                >
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'custom-quick-view__img placeholder-svg' }}
              {% endif %}
            </div>

            <!-- Right: Detailed info container -->
            <div class="custom-quick-view__info-container">
              <h3 id="modal-title-{{ product.id }}" class="custom-quick-view__title">{{ product.title }}</h3>
              <div class="custom-quick-view__price-container">
                <span class="custom-quick-view__price">{{ variant.price | money }}</span>
                {% if variant.compare_at_price > variant.price %}
                  <span class="custom-quick-view__compare-price">{{ variant.compare_at_price | money }}</span>
                {% endif %}
              </div>
              <div class="custom-quick-view__description">
                {{ product.description | strip_html | truncate: 90 }}
              </div>
            </div>
          </div>

          {% comment %} SECOND & THIRD ROW FORM TO SEND PRODUCT DATA THROUGH BODY WHEN ADDED TO CART {% endcomment %}
          <form class="custom-quick-view-form">
            <input type="hidden" name="id" value="{{ variant.id }}">

            {% comment %} SECOND ROW: Choose product variants {% endcomment %}
            <div class="custom-quick-view__second-row">
              {% if has_multiple_variants %}
                <div class="custom-quick-view-options">
                  {% comment %} We prioritize color selectors first as appears in the figma design {% endcomment %}
                  {% for option in product.options_with_values %}
                    {% assign option_name_downcase = option.name | downcase %}
                    {% if option_name_downcase contains 'color' or option_name_downcase contains 'colour' %}
                      <div class="custom-option-group" data-option-index="{{ forloop.index0 }}">
                        <span class="custom-option-label">{{ option.name }}:</span>
                        {% liquid
                          # Map option choices to align CSS-powered indicator slides under the active option value
                          assign active_color_idx = 0
                          for value in option.values
                            if option.selected_value == value
                              assign active_color_idx = forloop.index0
                            endif
                          endfor
                        %}
                        <div
                          class="custom-option-values custom-option-values--color"
                          style="--total-options: {{ option.values.size }}; --active-index: {{ active_color_idx }};"
                        >
                          <div class="custom-color-indicator"></div>
                          {% for value in option.values %}
                            <label class="custom-option-value">
                              <input
                                type="radio"
                                name="option-{{ product.id }}-{{ option.name | handle }}"
                                value="{{ value | escape }}"
                                {% if option.selected_value == value %}
                                  checked
                                {% endif %}
                              >
                              <span class="custom-color-strip" style="background-color: {{ value | downcase }};"></span>
                              <span class="custom-option-value-text">{{ value }}</span>
                            </label>
                          {% endfor %}
                        </div>
                      </div>
                    {% endif %}
                  {% endfor %}

                  {% comment %} Second, render dropdown for sizes as in the figma design {% endcomment %}
                  {% for option in product.options_with_values %}
                    {% assign option_name_downcase = option.name | downcase %}
                    {% unless option_name_downcase contains 'color' or option_name_downcase contains 'colour' %}
                      <div class="custom-option-group" data-option-index="{{ forloop.index0 }}">
                        <span class="custom-option-label">{{ option.name }}:</span>
                        {% comment %} We keep these radio buttons hidden to manage variant state internally while maintaining form compatibility {% endcomment %}
                        <div class="custom-option-values custom-option-values--hidden" style="display: none;">
                          {% for value in option.values %}
                            <label class="custom-option-value">
                              <input
                                type="radio"
                                name="option-{{ product.id }}-{{ option.name | handle }}"
                                value="{{ value | escape }}"
                                {% if option.selected_value == value %}
                                  checked
                                {% endif %}
                              >
                              <span class="custom-option-value-text">{{ value }}</span>
                            </label>
                          {% endfor %}
                        </div>

                        {% comment %} Our custom selector trigger that visually replaces the default system select elements {% endcomment %}
                        <div class="custom-dropdown-select">
                          <button type="button" class="custom-dropdown-select__trigger">
                            <span class="custom-dropdown-select__trigger-text">
                              {% if option.selected_value %}
                                {{ option.selected_value }}
                              {% else %}
                                Choose your size
                              {% endif %}
                            </span>
                            <span class="custom-dropdown-select__trigger-arrow">
                              <svg
                                viewBox="0 0 24 24"
                                width="16"
                                height="16"
                                stroke="currentColor"
                                stroke-width="2"
                                fill="none"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              >
                                <polyline points="6 9 12 15 18 9"></polyline>
                              </svg>
                            </span>
                          </button>
                          <div class="custom-dropdown-select__options">
                            {% for value in option.values %}
                              <div class="custom-dropdown-select__option" data-value="{{ value | escape }}">
                                {{ value }}
                              </div>
                            {% endfor %}
                          </div>
                        </div>
                      </div>
                    {% endunless %}
                  {% endfor %}
                </div>
              {% else %}
                <p class="custom-quick-view__no-variants-text" style="margin: 0; font-size: 13px; color: #888;">
                  Standard edition
                </p>
              {% endif %}
            </div>

            {% comment %} Checkout functional submission (add to cart) button {% endcomment %}
            <div class="custom-quick-view__third-row">
              <button
                type="submit"
                class="custom-quick-view-submit"
                {% unless variant.available %}
                  disabled
                {% endunless %}
              >
                <span class="custom-submit-text">
                  {% if variant.available %}
                    Add to Cart
                  {% else %}
                    Sold Out
                  {% endif %}
                </span>
                {% if variant.available %}
                  <svg
                    viewBox="0 0 24 24"
                    width="24"
                    height="24"
                    stroke="currentColor"
                    stroke-width="1.5"
                    fill="none"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="custom-submit-arrow"
                  >
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                {% endif %}
              </button>
            </div>
          </form>
        </div>
      </div>
    </custom-quick-view>
  {% endfor %}
</div>

{% comment %} Notification toast that drops down from the top to confirm the added product(s) to the shopping cart {% endcomment %}
<div id="custom-cart-toast" class="custom-cart-toast">
  <div class="custom-cart-toast__content">
    <div class="custom-cart-toast__header">
      <span class="custom-cart-toast__checkmark">&check;</span>
      <span class="custom-cart-toast__message">Added to cart successfully!</span>
    </div>
    <div class="custom-cart-toast__footer">
      <a href="{{ routes.cart_url }}" class="custom-cart-toast__link">View Cart</a>
      <a href="{{ routes.checkout_url }}" class="custom-cart-toast__link custom-cart-toast__link--checkout">Checkout</a>
    </div>
  </div>
</div>
{{ 'custom-products-grid.css' | asset_url | stylesheet_tag }}

<style>
  #custom-products-grid-{{ section.id }} {
    --columns-desktop: {{ section.settings.columns_desktop | default: 4 }};
    --gap-desktop: {{ section.settings.gap_desktop | default: 24 }}px;
    --columns-mobile: {{ section.settings.columns_mobile | default: 2 }};
    --gap-mobile: {{ section.settings.gap_mobile | default: 12 }}px;

    padding-top: {{ section.settings.padding_top_desktop | default: 16 }}px;
    padding-right: {{ section.settings.padding_right_desktop | default: 8 }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop | default: 16 }}px;
    padding-left: {{ section.settings.padding_left_desktop | default: 8 }}px;
  }

  /* Position and style the main grid heading */
  #custom-products-grid-{{ section.id }} .custom-products-grid__title {
    text-align: {{ section.settings.heading_alignment_desktop | default: 'center' }};
    font-size: calc(var(--font-h2--size) * ({{ section.settings.heading_size_desktop | default: 32 }} / 32.0));
    color: {{ section.settings.heading_color_desktop | default: '#000000' }};
  }

  /* Adjust heading text sizing on mobile so it doesn't wrap awkwardly */
  @media screen and (max-width: 768px) {
    #custom-products-grid-{{ section.id }} .custom-products-grid__title {
      text-align: {{ section.settings.heading_alignment_mobile | default: 'center' }};
      font-size: calc(var(--font-h2--size) * ({{ section.settings.heading_size_mobile | default: 24 }} / 24.0));
      color: {{ section.settings.heading_color_mobile | default: section.settings.heading_color_desktop | default: '#000000' }};
    }
  }

  /* Compact the outer grid margins on mobile viewports to make the layout feel spacious */
  @media screen and (max-width: 768px) {
    #custom-products-grid-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile | default: 12 }}px;
      padding-right: {{ section.settings.padding_right_mobile | default: 8 }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile | default: 12 }}px;
      padding-left: {{ section.settings.padding_left_mobile | default: 8 }}px;
    }
  }
</style>
<script src="{{ 'custom-products-grid.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Custom Products Grid",
  "tag": "section",
  "class": "shopify-section-custom-products-grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Featured Products"
    },
    {
      "type": "header",
      "content": "Heading (Desktop)"
    },
    {
      "type": "select",
      "id": "heading_alignment_desktop",
      "label": "Alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 16,
      "max": 72,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 32
    },
    {
      "type": "color",
      "id": "heading_color_desktop",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Heading (Mobile)"
    },
    {
      "type": "select",
      "id": "heading_alignment_mobile",
      "label": "Alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 14,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 24
    },
    {
      "type": "color",
      "id": "heading_color_mobile",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Products to Display",
      "limit": 24
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max Products to Show",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "Grid (Desktop)"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "rows_desktop",
      "label": "Rows",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "label": "Gap",
      "min": 0,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Grid (Mobile)"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "rows_mobile",
      "label": "Rows",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Padding (Desktop)"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_right_desktop",
      "label": "Padding Right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_left_desktop",
      "label": "Padding Left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Padding (Mobile)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_right_mobile",
      "label": "Padding Right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_left_mobile",
      "label": "Padding Left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Custom Products Grid",
      "category": "Test Sections"
    }
  ]
}
{% endschema %}
