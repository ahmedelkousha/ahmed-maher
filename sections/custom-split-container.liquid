<section id="custom-split-{{ section.id }}" class="custom-split">
  <div class="custom-split__container">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'text_box' %}
          <div id="block-{{ block.id }}" class="custom-split__text-box" {{ block.shopify_attributes }}>
            {%- comment -%}
              Render the desktop copy block (Heading & Subheading). We group these separately from mobile
              so that we can toggle layouts cleanly via CSS media queries without duplicating markup containers.
            {%- endcomment -%}
            <div class="custom-split__text-desktop">
              {% if block.settings.heading_desktop != blank %}
                <h2 class="custom-split__heading">{{ block.settings.heading_desktop }}</h2>
              {% endif %}
              {% if block.settings.subheading_desktop != blank %}
                <div class="custom-split__subheading">{{ block.settings.subheading_desktop }}</div>
              {% endif %}
            </div>

            {%- comment -%}
              Render the mobile copy block. If the mobile custom text settings are left empty by the editor,
              we automatically fall back to using the desktop heading/subheading values to prevent layout gaps.
            {%- endcomment -%}
            <div class="custom-split__text-mobile">
              {% if block.settings.heading_mobile != blank %}
                <h2 class="custom-split__heading">{{ block.settings.heading_mobile }}</h2>
              {% elsif block.settings.heading_desktop != blank %}
                <h2 class="custom-split__heading">{{ block.settings.heading_desktop }}</h2>
              {% endif %}
              {% if block.settings.subheading_mobile != blank %}
                <div class="custom-split__subheading">{{ block.settings.subheading_mobile }}</div>
              {% elsif block.settings.subheading_desktop != blank %}
                <div class="custom-split__subheading">{{ block.settings.subheading_desktop }}</div>
              {% endif %}
            </div>

            {% if block.settings.button_text != blank %}
              {% render 'custom-button',
                class: 'custom-split__btn',
                text_class: 'custom-split__btn-text',
                icon_class: 'custom-split__btn-icon',
                link: block.settings.button_link,
                text: block.settings.button_text,
                icon: block.settings.button_icon
              %}
            {% endif %}
          </div>

        {% when 'image' %}
          <div id="block-{{ block.id }}" class="custom-split__image-box" {{ block.shopify_attributes }}>
            {%- comment -%}
              Render the desktop-specific image. We request a wide image width (1400px) from Shopify's CDN
              for high definition displays.
            {%- endcomment -%}
            <div class="custom-split__img-desktop">
              {% if block.settings.image_desktop != blank %}
                <img
                  src="{{ block.settings.image_desktop | image_url: width: 1400 }}"
                  alt="{{ block.settings.image_desktop.alt | default: 'Section Image' | escape }}"
                  class="custom-split__img"
                  width="{{ block.settings.image_desktop.width }}"
                  height="{{ block.settings.image_desktop.height }}"
                >
              {% else %}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'custom-split__img placeholder-svg' }}
              {% endif %}
            </div>

            {%- comment -%}
              Render the mobile-specific image. If the mobile image picker is blank, we automatically fall back
              to the desktop image (scaling it down to 800px width for better mobile page load speed).
            {%- endcomment -%}
            <div class="custom-split__img-mobile">
              {% if block.settings.image_mobile != blank %}
                <img
                  src="{{ block.settings.image_mobile | image_url: width: 800 }}"
                  alt="{{ block.settings.image_mobile.alt | default: 'Section Image Mobile' | escape }}"
                  class="custom-split__img"
                  loading="lazy"
                  width="{{ block.settings.image_mobile.width }}"
                  height="{{ block.settings.image_mobile.height }}"
                >
              {% elsif block.settings.image_desktop != blank %}
                <img
                  src="{{ block.settings.image_desktop | image_url: width: 800 }}"
                  alt="{{ block.settings.image_desktop.alt | default: 'Section Image' | escape }}"
                  class="custom-split__img"
                  loading="lazy"
                  width="{{ block.settings.image_desktop.width }}"
                  height="{{ block.settings.image_desktop.height }}"
                >
              {% else %}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'custom-split__img placeholder-svg' }}
              {% endif %}
            </div>
          </div>
      {% endcase %}
    {% endfor %}
  </div>
</section>

{{ 'custom-split-container.css' | asset_url | stylesheet_tag }}

<style>
  /* Establish main layout width constraints and padding properties for the split content columns */
  #custom-split-{{ section.id }} {
    width: 100%;
    max-width: {{ section.settings.container_width_desktop | default: 1440 }}px;
    margin: 0 auto;
    overflow: hidden;
    background-color: {{ section.settings.background_color_desktop | default: '#ffffff' }};
    padding-left: {{ section.settings.section_padding_left_desktop | default: 0 }}px;
    padding-right: {{ section.settings.section_padding_right_desktop | default: 0 }}px;
  }

  @media screen and (max-width: 768px) {
    #custom-split-{{ section.id }} {
      background-color: {{ section.settings.background_color_mobile | default: section.settings.background_color_desktop | default: '#ffffff' }};
      padding-left: {{ section.settings.section_padding_left_mobile | default: 0 }}px;
      padding-right: {{ section.settings.section_padding_right_mobile | default: 0 }}px;
    }
  }

  /* Dynamically generate block-specific formatting rules based on the blocks customizer settings */
  {% for block in section.blocks %}
    {% if block.type == 'text_box' %}
      /* Desktop styling rules for the text-box of the split container */
      #block-{{ block.id }} {
        background: {{ block.settings.bg_color_desktop | default: '#ffffff' }};
        color: {{ block.settings.text_color_desktop | default: '#000000' }};
        padding-top: {{ block.settings.padding_top_desktop | default: 40 }}px;
        padding-right: {{ block.settings.padding_right_desktop | default: 0 }}px;
        padding-bottom: {{ block.settings.padding_bottom_desktop | default: 40 }}px;
        padding-left: {{ block.settings.padding_left_desktop | default: 60 }}px;
        align-items: {{ block.settings.alignment_desktop | default: 'flex-start' }};
        text-align: {{ block.settings.alignment_desktop | default: 'flex-start' | replace: 'flex-start', 'left' | replace: 'flex-end', 'right' }};
        gap: {{ block.settings.gap_desktop | default: 40 }}px;
        width: {{ block.settings.width_desktop | default: 40 }}%;
        flex-shrink: 0;
        min-width: 520px;
      }
      #block-{{ block.id }} .custom-split__heading {
        {% if block.settings.use_global_font_size %}
          font-size: var(--font-h2--size);
        {% else %}
          font-size: {{ block.settings.heading_size_desktop | default: 70 }}px;
        {% endif %}
      }
      @media screen and (min-width: 769px) and (max-width: 1280px) {
        #block-{{ block.id }} .custom-split__heading {
          font-size: 56px !important;
        }
        #block-{{ block.id }} .custom-split__subheading {
          font-size: 14.4px !important;
        }
        #block-{{ block.id }} {
          gap: 35px;
        }
      }

      #block-{{ block.id }} .custom-split__subheading {
        {% if block.settings.use_global_font_size %}
          font-size: var(--font-paragraph--size);
          font-weight: var(--font-paragraph--weight);
          letter-spacing: var(--font-paragraph--letter-spacing);
        {% else %}
          font-size: {{ block.settings.subheading_size_desktop | default: 20 }}px;
          font-weight: 400;
          letter-spacing: -0.5px;
        {% endif %}
      }

      /* Shape and position the main call-to-action button, leaving extra space if it includes a leading graphic or icon */
      #block-{{ block.id }} .custom-split__btn {
        padding: {{ block.settings.btn_padding_top_desktop | default: 9 }}px {{ block.settings.btn_padding_right_desktop | default: 21 }}px {{ block.settings.btn_padding_bottom_desktop | default: 9 }}px {{ block.settings.btn_padding_left_desktop | default: 21 }}px;
      }
      #block-{{ block.id }} .custom-split__btn {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: {{ block.settings.btn_icon_gap_desktop | default: 18 }}px;
        {% if block.settings.use_global_font_size %}
          font-size: var(--font-paragraph--size);
        {% else %}
          font-size: {{ block.settings.btn_font_size_desktop | default: 16 }}px;
        {% endif %}
        background-color: {{ block.settings.btn_bg_color | default: '#000000' }};
        color: {{ block.settings.btn_text_color | default: '#ffffff' }};
      }
      #block-{{ block.id }} .custom-split__btn::before {
        background-color: {{ block.settings.btn_hover_bg | default: '#FFF544' }};
      }
      #block-{{ block.id }} .custom-split__btn:hover {
        color: {{ block.settings.btn_hover_color | default: '#000000' }};
      }

      /* Dynamically invert the button's icon graphic to guarantee a clear visual contrast against light/dark themes */
      {%- assign btn_bg_brightness = block.settings.btn_bg_color | default: '#000000' | color_brightness -%}
      {% if btn_bg_brightness < 128 %}
        #block-{{ block.id }} .custom-split__btn-icon {
          filter: invert(1);
        }
      {% else %}
        #block-{{ block.id }} .custom-split__btn-icon {
          filter: none;
        }
      {% endif %}
      {%- assign btn_hover_brightness = block.settings.btn_hover_bg | default: '#FFF544' | color_brightness -%}
      {% if btn_hover_brightness < 128 %}
        #block-{{ block.id }} .custom-split__btn:hover .custom-split__btn-icon {
          filter: invert(1);
        }
      {% else %}
        #block-{{ block.id }} .custom-split__btn:hover .custom-split__btn-icon {
          filter: none;
        }
      {% endif %}

      /* Re-orient the text columns on smaller mobile screens so the content stacks without issues */
      @media screen and (max-width: 768px) {
        #block-{{ block.id }} {
          background: {{ block.settings.bg_color_mobile | default: block.settings.bg_color_desktop | default: '#ffffff' }};
          color: {{ block.settings.text_color_mobile | default: block.settings.text_color_desktop | default: '#000000' }};
          padding-top: {{ block.settings.padding_top_mobile | default: 30 }}px;
          padding-right: {{ block.settings.padding_right_mobile | default: 20 }}px;
          padding-bottom: {{ block.settings.padding_bottom_mobile | default: 30 }}px;
          padding-left: {{ block.settings.padding_left_mobile | default: 20 }}px;
          align-items: {{ block.settings.alignment_mobile | default: 'center' }};
          text-align: {{ block.settings.alignment_mobile | default: 'center' | replace: 'flex-start', 'left' | replace: 'flex-end', 'right' }};
          gap: {{ block.settings.gap_mobile | default: 16 }}px;
          width: 100%;
        }
        #block-{{ block.id }} .custom-split__heading {
          {% if block.settings.use_global_font_size %}
            font-size: var(--font-h2--size);
          {% else %}
            font-size: {{ block.settings.heading_size_mobile | default: 36 }}px;
          {% endif %}
        }
        #block-{{ block.id }} .custom-split__subheading {
          {% if block.settings.use_global_font_size %}
            font-size: var(--font-paragraph--size);
          {% else %}
            font-size: {{ block.settings.subheading_size_mobile | default: 16 }}px;
          {% endif %}
        }
        #block-{{ block.id }} .custom-split__btn {
          padding: {{ block.settings.btn_padding_top_mobile | default: 9 }}px {{ block.settings.btn_padding_right_mobile | default: 21 }}px {{ block.settings.btn_padding_bottom_mobile | default: 9 }}px {{ block.settings.btn_padding_left_mobile | default: 21 }}px;
        }
        #block-{{ block.id }} .custom-split__btn {
          display: flex;
          justify-content: center;
          align-items: center;
          gap: {{ block.settings.btn_icon_gap_mobile | default: 18 }}px;
          {% if block.settings.use_global_font_size %}
            font-size: var(--font-paragraph--size);
          {% else %}
            font-size: {{ block.settings.btn_font_size_mobile | default: 14 }}px;
          {% endif %}
        }
      }
    {% endif %}

    {% if block.type == 'image' %}
      /* Set desktop sizing ratios for the image column on text box with image container */
      #block-{{ block.id }} {
        width: {{ block.settings.width_desktop | default: 60 }}%;
        flex-grow: 1;
        flex-shrink: 0;
      }
      @media screen and (max-width: 768px) {
        #block-{{ block.id }} {
          width: 100%;
        }
      }
    {% endif %}
  {% endfor %}

  /* Conditionally render or hide elements based on active screen sizes selected in the customizer */
  {%- for block in section.blocks -%}
    {%- if block.settings.hide_on_desktop -%}
      @media screen and (min-width: 769px) {
        #block-{{ block.id }} {
          display: none !important;
        }
      }
    {%- endif -%}
    {%- if block.settings.hide_on_mobile -%}
      @media screen and (max-width: 768px) {
        #block-{{ block.id }} {
          display: none !important;
        }
      }
    {%- endif -%}
  {%- endfor -%}
</style>

{% schema %}
{
