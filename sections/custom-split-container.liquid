  "tag": "section",
  "class": "shopify-section-custom-split",
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "header",
      "content": "Desktop"
    },
    {
      "type": "range",
      "id": "section_padding_left_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left",
      "default": 0
