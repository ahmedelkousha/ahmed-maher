          "max": 40,
          "step": 1,
          "unit": "px",
          "label": "Mobile Font Size",
          "default": 18
        },
        {
          "type": "header",
          "content": "Alignment Settings"
        },
        {
          "type": "select",
          "id": "logo_align_desktop",
          "label": "Desktop Alignment",
          "options": [
            { "value": "flex-start", "label": "Left" },
