          "label": "Logo Text (Fallback)",
          "default": "My Shop"
        },
        {
          "type": "header",
          "content": "Fallback Text Size"
        },
        {
          "type": "range",
          "id": "logo_text_size_desktop",
          "min": 10,
          "max": 40,
          "step": 1,
          "unit": "px",
          "label": "Desktop Font Size",
          "default": 24
        },
        {
          "type": "range",
          "id": "logo_text_size_mobile",
