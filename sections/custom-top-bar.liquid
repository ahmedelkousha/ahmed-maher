  "tag": "section",
  "class": "shopify-section-custom-top-bar",
  "settings": [
    {
      "type": "color",
      "id": "top_bar_bg",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "top_bar_color",
      "label": "Text Color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "limit": 1,
